# Copy this file to .env and fill in the values
# Never commit .env to git

# Django
DEBUG=False
SECRET_KEY=replace-this-with-a-random-50-char-string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exceptioniq

# Frontend origin (used for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# AI Service
AI_SERVICE_URL=http://localhost:8001

# Groq (optional — if not set, rule-based fallback activates)
GROQ_API_KEY=

# Dev Tools (set to true on developer machines only)
VITE_DEV_TOOLS=true

# Zoho Books OAuth & Client Configuration
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:8000/api/v1/integrations/zoho/callback/
FRONTEND_URL=http://localhost:5173

# --- Render deployment env vars ---
# These are set in the Render dashboard / render.yaml:
#   VITE_API_URL    = https://<backend>.onrender.com/api/v1       (frontend service)
#   FRONTEND_ORIGIN = https://<frontend>.onrender.com              (backend service)
#   AI_SERVICE_URL  = https://<ai-service>.onrender.com            (backend service)
#   SESSION_COOKIE_SAMESITE = None
#   SESSION_COOKIE_SECURE   = True
#   CSRF_COOKIE_SAMESITE    = None
#   CSRF_COOKIE_SECURE      = True
#   RUN_SEED = true  (first deploy only)
